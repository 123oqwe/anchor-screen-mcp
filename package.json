{
  "name": "@anchor/screen-mcp",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Cross-platform screen capture + VLM understanding as MCP server. Take a screenshot, send to a vision LLM, return what's on screen. Mac/Win/Linux.",
  "bin": { "anchor-screen-mcp": "dist/index.js" },
  "main": "dist/index.js",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
